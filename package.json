{
    "private": true,
    "workspaces": {
        "packages": [
            "platform/core/*",
            "platform/packages/*",
            "platform/plugins/*",
            "platform/themes/*"
        ]
    },
    "scripts": {
        "dev": "npm run development",
        "development": "mix",
        "watch": "mix watch",
        "watch-poll": "mix watch -- --watch-options-poll=1000",
        "hot": "mix watch --hot",
        "prod": "npm run production",
        "production": "mix --production",
        "screenshot": "node platform/core/base/resources/js/screenshot.js",
        "admin-screenshot": "node platform/core/base/resources/js/admin-screenshot.js"
    },
    "devDependencies": {
        "@fullhuman/postcss-purgecss": "^8.0.0",
        "autoprefixer": "^10.4.27",
        "cross-env": "^10.1.0",
        "css-loader": "^7.1.4",
        "glob": "^13.0.6",
        "laravel-mix": "^6.0.49",
        "postcss": "^8.5.8",
        "prettier": "^3.8.1",
        "puppeteer": "^24.40.0",
        "resolve-url-loader": "^5.0.0",
        "sass": "^1.98.0",
        "sass-loader": "^16.0.7",
        "vue-loader": "^17.4.2"
    },
    "dependencies": {
        "axios": "^1.14.0",
        "bootstrap": "5.3.8",
        "cropperjs": "^1.6.2",
        "epic-spinners": "^2.0.0",
        "jquery": "4.0.0",
        "lodash": "^4.17.23",
        "moment": "^2.30.1",
        "sanitize-html": "^2.17.2",
        "tiny-emitter": "^2.1.0",
        "vue": "^3.5.31"
    }
